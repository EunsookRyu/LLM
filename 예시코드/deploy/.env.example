# .env.example — Docker Compose 환경변수 템플릿
# 이 파일을 .env로 복사한 뒤 값을 채워 넣으세요.

# ── HyperCLOVA X API (2단계) ──
CLOVA_API_KEY=여기에_API_키를_입력하세요
CLOVA_API_GATEWAY_KEY=여기에_API_Gateway_키를_입력하세요

# ── Qdrant 설정 ──
QDRANT_COLLECTION_NAME=documents
EMBEDDING_VECTOR_SIZE=1024

# ── LLM 엔진 설정 (3단계) ──
# clova | ollama | vllm
LLM_PROVIDER=clova
LLM_BASE_URL=http://ollama:11434
LLM_MODEL_NAME=gemma3:12b

# ── 임베딩 엔진 설정 (3단계) ──
# clova | local
EMBEDDING_PROVIDER=clova
EMBEDDING_BASE_URL=http://embedding-server:8001

# ── 로컬 임베딩 모델 경로 ──
BGE_M3_PATH=/path/to/bge-m3

# ── API 인증 키 (운영 환경) ──
API_KEY=
